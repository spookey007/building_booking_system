# App runtime — copy "Connection string" from Neon console (direct host is fine).
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Prisma CLI (migrate deploy / migrate dev) — copy "Pooled connection" from Neon console.
MIGRATE_DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

JWT_SECRET="replace-with-a-long-random-secret-min-32-chars"

# Setup: npm run db:ping && npm run prisma:migrate:deploy && npm run prisma:seed
# migrate:deploy uses Neon HTTPS (same as db:ping). Use migrate:deploy:tcp only if TCP 5432 works.
