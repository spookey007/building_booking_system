# PostgreSQL connection string (required).
# On Vercel + Neon/Supabase, use the pooled / serverless URL for DATABASE_URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# Secret for JWT session cookies (required). Use a long random string in production.
JWT_SECRET="replace-with-a-long-random-secret-min-32-chars"

# --- Vercel ---
# Add the same variables in: Project Settings → Environment Variables (Production + Preview).
#
# Migrations: run once per schema change, e.g. from your machine or CI:
#   DATABASE_URL="..." npm run prisma:migrate:deploy
# Or set the Vercel "Build Command" to: npm run vercel-build
# (only if your DATABASE_URL supports DDL; Neon often needs a direct non-pooled URL for migrate.)
