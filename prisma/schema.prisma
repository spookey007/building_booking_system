generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum UnitKind {
  RESIDENTIAL
  COMMERCIAL
  PENTHOUSE
}

enum UnitListingStatus {
  AVAILABLE
  HOLD
  BOOKED
  SOLD
  CANCELLED
}

enum BookingStatus {
  DRAFT
  CONFIRMED
  CANCELLED
  COMPLETED
  TRANSFERRED
  SWITCHED
}

enum BookingMode {
  REGULAR
  TRANSFER
  CANCEL
  SWITCHING
  GIFT
}

enum InstallmentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

enum PaymentMode {
  CASH
  BANK_TRANSFER
  CHEQUE
  ONLINE
  OTHER
}

enum DocumentOwnerType {
  CUSTOMER
  BOOKING
  UNIT
  PAYMENT
  USER
}

enum LiabilityStatus {
  OPEN
  SETTLED
}

model User {
  id           String       @id @default(cuid())
  fullName     String       @db.VarChar(200)
  email        String       @unique @db.VarChar(320)
  phone        String?      @db.VarChar(32)
  passwordHash String       @db.VarChar(255)
  status       UserStatus   @default(ACTIVE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  roles        UserRole[]
  bookings     Booking[]    @relation("BookingCreatedBy")
  documents    Document[]
  auditLogs    AuditLog[]

  @@index([status])
}

model Role {
  id          String           @id @default(cuid())
  code        String           @unique
  name        String
  description String?
  users       UserRole[]
  permissions RolePermission[]
  menuItems   RoleMenuItem[]
}

model Permission {
  id          String           @id @default(cuid())
  code        String           @unique
  name        String
  module      String
  description String?
  roles       RolePermission[]
}

model UserRole {
  id         String   @id @default(cuid())
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([roleId])
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
}

model MenuItem {
  id         String        @id @default(cuid())
  itemKey    String        @unique
  label      String
  route      String?
  icon       String?
  sortOrder  Int           @default(0)
  isActive   Boolean       @default(true)
  parentId   String?
  parent     MenuItem?     @relation("MenuTree", fields: [parentId], references: [id], onDelete: SetNull)
  children   MenuItem[]    @relation("MenuTree")
  roleAccess RoleMenuItem[]

  @@index([parentId, sortOrder])
  @@index([isActive, sortOrder])
}

model RoleMenuItem {
  id         String   @id @default(cuid())
  roleId     String
  menuItemId String
  canView    Boolean  @default(true)
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, menuItemId])
  @@index([menuItemId])
}

model Project {
  id         String   @id @default(cuid())
  name       String   @db.VarChar(200)
  code       String   @unique @db.VarChar(64)
  city       String?  @db.VarChar(120)
  address    String?  @db.VarChar(500)
  status     Boolean  @default(true)
  launchDate DateTime?
  towers     Tower[]
  units      Unit[]
  bookings   Booking[]
}

model Tower {
  id          String   @id @default(cuid())
  projectId   String
  code        String   @db.VarChar(16)
  name        String   @db.VarChar(200)
  totalFloors Int?
  isActive    Boolean  @default(true)
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  units       Unit[]

  @@unique([projectId, code])
  @@index([projectId, isActive])
}

model UnitCategory {
  id          String   @id @default(cuid())
  code        String   @unique @db.VarChar(64)
  name        String   @db.VarChar(200)
  description String?
  units       Unit[]
}

model FacingType {
  id    String @id @default(cuid())
  code  String @unique @db.VarChar(64)
  name  String @db.VarChar(200)
  units Unit[]
}

model Unit {
  id              String            @id @default(cuid())
  projectId       String
  towerId         String
  categoryId      String?
  facingTypeId    String?
  prefix          String?           @db.VarChar(16)
  unitNo          String            @db.VarChar(32)
  serialNo        Int?
  floorNo         Int?
  areaSqft        Decimal           @db.Decimal(12, 2)
  rooms           Int?
  unitKind        UnitKind
  listingStatus   UnitListingStatus @default(AVAILABLE)
  basePrice       Decimal?          @db.Decimal(14, 2)
  transferCharges Decimal?          @db.Decimal(14, 2)
  notes           String?           @db.VarChar(2000)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  category        UnitCategory?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  facingType      FacingType?       @relation(fields: [facingTypeId], references: [id], onDelete: SetNull)
  project         Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tower           Tower             @relation(fields: [towerId], references: [id], onDelete: Restrict)
  bookings        Booking[]
  switchTargets   Booking[]         @relation("SwitchToUnit")

  @@unique([projectId, towerId, unitNo], map: "ux_unit_project_tower_no")
  @@index([unitKind, listingStatus], map: "idx_unit_kind_status")
  @@index([towerId, floorNo], map: "idx_unit_tower_floor")
  @@index([categoryId, facingTypeId], map: "idx_unit_category_facing")
  @@index([projectId, serialNo], map: "idx_unit_project_serial")
}

model Customer {
  id            String     @id @default(cuid())
  fullName      String     @db.VarChar(200)
  fatherHusband String?    @db.VarChar(200)
  phone         String?    @db.VarChar(32)
  phoneOffice   String?    @db.VarChar(32)
  phoneRes      String?    @db.VarChar(32)
  whatsapp      String?    @db.VarChar(32)
  email         String?    @db.VarChar(320)
  cnic          String?    @db.VarChar(20)
  passportNo    String?    @db.VarChar(24)
  nationality   String?    @db.VarChar(64)
  postalAddress String?    @db.VarChar(500)
  income        Decimal?   @db.Decimal(14, 2)
  age           Int?
  occupation    String?    @db.VarChar(120)
  broker        String?    @db.VarChar(200)
  careOf        String?    @db.VarChar(200)
  createdAt     DateTime   @default(now())
  bookings      Booking[]
  nominees      Nominee[]

  @@index([fullName], map: "idx_customer_name")
  @@index([phone], map: "idx_customer_phone")
  @@index([cnic], map: "idx_customer_cnic")
}

model Nominee {
  id         String   @id @default(cuid())
  customerId String
  name       String   @db.VarChar(200)
  relation   String?  @db.VarChar(64)
  fatherName String?  @db.VarChar(200)
  address    String?  @db.VarChar(500)
  cnic       String?  @db.VarChar(20)
  cell       String?  @db.VarChar(32)
  passportNo String?  @db.VarChar(24)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model Booking {
  id                   String        @id @default(cuid())
  bookingNo            String        @unique @db.VarChar(64)
  projectId            String
  unitId               String
  previousBookingId    String?
  customerId           String
  bookedByUserId       String
  bookingDate          DateTime
  status               BookingStatus @default(DRAFT)
  mode                 BookingMode   @default(REGULAR)
  transferDate         DateTime?
  switchingDate        DateTime?
  switchDate           DateTime?
  switchToUnitId       String?
  cancelDate           DateTime?
  currentDateAtBooking DateTime?
  categoryAtBooking    String?       @db.VarChar(64)
  unitPrice            Decimal?      @db.Decimal(14, 2)
  cashPayable          Decimal?      @db.Decimal(14, 2)
  discountAmount       Decimal?      @db.Decimal(14, 2)
  grossTotal           Decimal?      @db.Decimal(14, 2)
  payableCost          Decimal?      @db.Decimal(14, 2)
  notes                String?       @db.VarChar(4000)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  createdBy            User          @relation("BookingCreatedBy", fields: [bookedByUserId], references: [id], onDelete: Restrict)
  customer             Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  previousBooking      Booking?      @relation("BookingHistory", fields: [previousBookingId], references: [id], onDelete: SetNull)
  nextBookings         Booking[]     @relation("BookingHistory")
  project              Project       @relation(fields: [projectId], references: [id], onDelete: Restrict)
  switchToUnit         Unit?         @relation("SwitchToUnit", fields: [switchToUnitId], references: [id], onDelete: SetNull)
  unit                 Unit          @relation(fields: [unitId], references: [id], onDelete: Restrict)
  plan                 PaymentPlan?
  payments             Payment[]     @relation("BookingPayments")
  sourcedPayments      Payment[]     @relation("PaymentSourceBooking")
  sourceLiabilities    CompanyLiability[] @relation("LiabilitySourceBooking")
  transferLiabilities  CompanyLiability[] @relation("LiabilityTransferBooking")

  @@index([status, bookingDate], map: "idx_booking_status_date")
  @@index([mode, bookingDate], map: "idx_booking_mode_date")
  @@index([unitId, status], map: "idx_booking_unit_status")
  @@index([customerId, bookingDate], map: "idx_booking_customer_date")
  @@index([previousBookingId], map: "idx_booking_previous")
}

model PaymentPlan {
  id                String               @id @default(cuid())
  bookingId         String               @unique
  planName          String               @db.VarChar(200)
  totalInstallments Int
  startDate         DateTime
  totalAmount       Decimal              @db.Decimal(14, 2)
  booking           Booking              @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  schedules         PaymentInstallment[]
}

model PaymentInstallment {
  id            String            @id @default(cuid())
  paymentPlanId String
  installmentNo Int
  dueDate       DateTime
  dueAmount     Decimal           @db.Decimal(14, 2)
  status        InstallmentStatus @default(PENDING)
  paymentPlan   PaymentPlan       @relation(fields: [paymentPlanId], references: [id], onDelete: Cascade)
  payments      Payment[]

  @@unique([paymentPlanId, installmentNo])
  @@index([status, dueDate], map: "idx_installment_status_due")
}

model Payment {
  id            String              @id @default(cuid())
  bookingId     String
  sourceBookingId String?
  installmentId String?
  paymentDate   DateTime
  amount        Decimal             @db.Decimal(14, 2)
  mode          PaymentMode
  referenceNo   String?             @db.VarChar(120)
  receivedBy    String?             @db.VarChar(200)
  notes         String?             @db.VarChar(1000)
  voidedAt      DateTime?
  voidReason    String?             @db.VarChar(500)
  booking       Booking             @relation("BookingPayments", fields: [bookingId], references: [id], onDelete: Cascade)
  sourceBooking Booking?            @relation("PaymentSourceBooking", fields: [sourceBookingId], references: [id], onDelete: SetNull)
  installment   PaymentInstallment? @relation(fields: [installmentId], references: [id], onDelete: SetNull)

  @@index([bookingId, paymentDate], map: "idx_payment_booking_date")
  @@index([mode, paymentDate], map: "idx_payment_mode_date")
  @@index([sourceBookingId], map: "idx_payment_source_booking")
  @@index([voidedAt], map: "idx_payment_voided")
}

model CompanyLiability {
  id                String          @id @default(cuid())
  sourceBookingId   String
  transferBookingId String?
  amount            Decimal         @db.Decimal(14, 2)
  reason            String          @db.VarChar(400)
  status            LiabilityStatus @default(OPEN)
  dueDate           DateTime?
  settledAt         DateTime?
  notes             String?         @db.VarChar(1000)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  sourceBooking     Booking         @relation("LiabilitySourceBooking", fields: [sourceBookingId], references: [id], onDelete: Cascade)
  transferBooking   Booking?        @relation("LiabilityTransferBooking", fields: [transferBookingId], references: [id], onDelete: SetNull)

  @@index([status, dueDate], map: "idx_liability_status_due")
  @@index([sourceBookingId], map: "idx_liability_source_booking")
  @@index([transferBookingId], map: "idx_liability_transfer_booking")
}

model Document {
  id          String            @id @default(cuid())
  ownerType   DocumentOwnerType
  ownerId     String            @db.VarChar(64)
  docType     String            @db.VarChar(120)
  fileUrl     String            @db.VarChar(2000)
  fileName    String            @db.VarChar(255)
  uploadedBy  String
  uploadedAt  DateTime          @default(now())
  uploadedByUser User           @relation(fields: [uploadedBy], references: [id], onDelete: Restrict)

  @@index([ownerType, ownerId], map: "idx_document_owner")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorUserId String
  entityType String   @db.VarChar(64)
  entityId   String   @db.VarChar(64)
  action     String   @db.VarChar(64)
  beforeData Json?
  afterData  Json?
  createdAt  DateTime @default(now())
  actor      User     @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([entityType, entityId, createdAt], map: "idx_audit_entity_date")
  @@index([actorUserId, createdAt], map: "idx_audit_actor_date")
}
